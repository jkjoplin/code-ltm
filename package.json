{
  "name": "code-ltm",
  "version": "0.1.0",
  "description": "A knowledge management system for AI coding agents",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "code-ltm": "./dist/index.js",
    "code-ltm-cli": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jkjoplin/code-ltm.git"
  },
  "homepage": "https://github.com/jkjoplin/code-ltm#readme",
  "bugs": {
    "url": "https://github.com/jkjoplin/code-ltm/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "cli": "tsx src/cli.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit",
    "api": "tsx src/api/index.ts",
    "api:dev": "tsx watch src/api/index.ts",
    "ui": "cd ui && npm run dev",
    "ui:build": "cd ui && npm run build",
    "ui:install": "cd ui && npm install",
    "prepublishOnly": "npm run build && npm run test:run"
  },
  "keywords": [
    "mcp",
    "ai",
    "knowledge-management",
    "claude",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "inquirer": "^13.2.2",
    "ora": "^9.2.0",
    "sqlite-vec": "^0.1.6",
    "uuid": "^10.0.0",
    "yaml": "^2.8.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
